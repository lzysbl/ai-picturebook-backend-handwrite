# App settings
APP_NAME=AI绘本故事生成系统
APP_ENV=development
APP_DEBUG=true

# Async DB URL (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./ai_story.db
# Async MySQL example:
# DATABASE_URL=mysql+aiomysql://root:你的密码@127.0.0.1:3306/ai_story?charset=utf8mb4

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
STORY_CACHE_TTL_SECONDS=1800

# Auth
SECRET_KEY=replace_this_with_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Upload
UPLOAD_DIR=uploads
