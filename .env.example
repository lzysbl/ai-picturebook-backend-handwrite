# 第一步：先把本文件复制为 .env 再改配置
APP_NAME=AI绘本故事生成系统
APP_ENV=development
APP_DEBUG=true

# 你可以先用 SQLite 跑通，再切 MySQL
DATABASE_URL=sqlite:///./ai_story.db
# DATABASE_URL=mysql+pymysql://root:你的密码@127.0.0.1:3306/ai_story?charset=utf8mb4

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
STORY_CACHE_TTL_SECONDS=1800

SECRET_KEY=replace_this_with_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=120
UPLOAD_DIR=uploads

