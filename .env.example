# =========================
# App
# =========================
APP_NAME=AI绘本故事生成系统
APP_ENV=development
APP_DEBUG=true
APP_PORT=8001

# =========================
# Database
# SQLite (default)
# =========================
DATABASE_URL=sqlite+aiosqlite:///./ai_story.db

# MySQL example:
# DATABASE_URL=mysql+aiomysql://root:your_password@127.0.0.1:3306/ai_story?charset=utf8mb4
MYSQL_ROOT_PASSWORD=please_change_mysql_password
MYSQL_DATABASE=ai_story

# =========================
# Security (JWT)
# =========================
SECRET_KEY=please_change_to_a_random_long_secret
ACCESS_TOKEN_EXPIRE_MINUTES=120

# =========================
# Upload
# =========================
UPLOAD_DIR=./uploads

# =========================
# AI Provider
# mock | qwen
# =========================
AI_PROVIDER=mock
QWEN_MODEL=qwen3.6-flash
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=

# =========================
# Redis (optional)
# =========================
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
STORY_CACHE_TTL_SECONDS=1800
QUALITY_CACHE_TTL_SECONDS=604800

# =========================
# Rate Limit
# =========================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_LIMIT=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_REGISTER_LIMIT=5
RATE_LIMIT_REGISTER_WINDOW_SECONDS=300
RATE_LIMIT_STORY_SUBMIT_LIMIT=5
RATE_LIMIT_STORY_SUBMIT_WINDOW_SECONDS=300

# =========================
# Judge (LLM-based Evaluation)
# =========================
JUDGE_ENABLED=false
JUDGE_MODEL=qwen3.6-plus
JUDGE_SAMPLES=3

# =========================
# Logging
# =========================
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
